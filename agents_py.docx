class MergerOutput(BaseModel):
    connections: List[Connection] = Field(default_factory=list, description="List of judged connections. Empty list if no connections exist.")


# ==================== Utility to Load Skills ====================
import os

def load_skill_instruction(skill_path: str) -> str:
    """Reads the massive SKILL.md file to inject into the Agent's brain."""
    try:
        with open(skill_path, 'r') as f:
            return f.read()
    except FileNotFoundError:
        return "You are an AI assistant. No specific skill loaded."

# ==================== Agent Definitions ====================

# 1. Orchestrator
orchestrator_agent = Agent(
    name="orchestrator",
    model="gemini-1.5-pro",
    instruction=load_skill_instruction('skills/orchestrator/SKILL.md')
)

# 2. Researcher
researcher_agent = Agent(
    name="researcher",
    model="gemini-1.5-flash",
    instruction=load_skill_instruction('skills/researcher/SKILL.md')
)

# 3. Extractor
extractor_agent = Agent(
    name="extractor",
    model="gemini-1.5-flash",
    instruction=load_skill_instruction('skills/extractor/SKILL.md'),
    output_schema=ExtractorOutput,
    output_key="extracted_nodes"
)
