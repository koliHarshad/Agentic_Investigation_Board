# Gemini API Key (Required for model calls and embeddings)
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily Search API Key (Required for web search)
TAVILY_API_KEY=your_tavily_api_key_here

# OpenSanctions API Key (Optional / if using OpenSanctions MCP/API)
OPENSANCTIONS_API_KEY=your_opensanctions_api_key_here

# Safety / Execution Cap Overrides (Optional)
MAX_TOTAL_DOCUMENTS=15
MAX_RESEARCH_ROUNDS=2
MAX_DOCS_PER_ROUND=10
MAX_DOCS_PER_EXTRACTOR_BATCH=3
MAX_MERGER_CANDIDATES_K=5
LLM_CALL_DELAY_SECONDS=2
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=5
